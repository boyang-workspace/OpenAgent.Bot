---
import { categories } from "@/config/site";

type Props = {
  eyebrow?: string;
  title?: string;
  description?: string;
  active?: string;
};

const { eyebrow, title, description, active } = Astro.props;
const isHome = Astro.url.pathname === "/";
const discoveryLinks = [
  { label: "Today", href: isHome ? "#today" : "/#today", key: "today" },
  { label: "Trending", href: isHome ? "#trending" : "/#trending", key: "trending" },
  { label: "Recently Added", href: isHome ? "#recent" : "/#recent", key: "recent" }
];
const resourceCategoryOrder = ["models", "agents", "skills", "memory-systems", "plugins"];
const resourceLinks = resourceCategoryOrder
  .map((slug) => categories.find((category) => category.slug === slug))
  .filter((category): category is (typeof categories)[number] => Boolean(category))
  .map((category) => ({ label: category.label, href: `/${category.slug}`, key: category.slug }));
const utilityLinks = [
  { label: "Tools", href: "/tools", key: "tools" },
  { label: "Blog", href: "/blog", key: "blog" },
  { label: "Manifesto", href: "/manifesto", key: "manifesto" }
];
const sectionLinks = [...discoveryLinks, ...resourceLinks, ...utilityLinks];
---

<div class="editorial-shell">
  <aside class="editorial-sidebar" aria-label="OpenAgent.bot sections">
    <div class="sidebar-card">
      <nav>
        <div class="nav-group">
          {discoveryLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
        </div>
        <div class="nav-group">
          {resourceLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
        </div>
        <div class="nav-group utility-group">
          {utilityLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
        </div>
      </nav>
    </div>
  </aside>

  <div class="mobile-rail" aria-label="OpenAgent.bot sections">
    {sectionLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
  </div>

  <div class="editorial-main">
    {
      title && (
        <header class="editorial-head">
          {eyebrow && <span class="eyebrow">{eyebrow}</span>}
          <h1>{title}</h1>
          {description && <p>{description}</p>}
        </header>
      )
    }
    <slot />
  </div>
</div>

<style>
  .editorial-shell {
    display: grid;
    gap: 26px;
    grid-template-columns: var(--sidebar) minmax(0, 1fr);
    margin: 0 auto;
    max-width: var(--page-max);
    padding: 26px 24px 64px;
  }

  .editorial-sidebar {
    position: relative;
  }

  .sidebar-card {
    position: sticky;
    top: 92px;
  }

  nav {
    display: grid;
    gap: 16px;
  }

  .nav-group {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 3px;
    padding-bottom: 14px;
  }

  .nav-group:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  nav a,
  .mobile-rail a {
    border-radius: 8px;
    color: var(--muted);
    font-weight: 500;
  }

  nav a {
    font-size: 0.93rem;
    padding: 8px 11px;
  }

  .utility-group {
    margin-top: 4px;
  }

  .utility-group a {
    color: var(--subtle);
    font-size: 0.86rem;
  }

  nav a:hover,
  nav a.active,
  .mobile-rail a:hover,
  .mobile-rail a.active {
    background: var(--surface);
    color: var(--ink);
  }

  nav a.active {
    background: var(--surface-tint);
    font-weight: 600;
  }

  .mobile-rail {
    display: none;
  }

  .editorial-main {
    min-width: 0;
    overflow: hidden;
  }

  .editorial-head {
    padding: 18px 0 28px;
  }

  .editorial-head h1 {
    font-size: 4rem;
    letter-spacing: 0;
    line-height: 1;
    margin: 8px 0 0;
    max-width: 900px;
  }

  .editorial-head p {
    font-size: 1.08rem;
    margin: 18px 0 0;
    max-width: 720px;
  }

  @media (max-width: 920px) {
    .editorial-shell {
      display: block;
      padding: 18px 0 48px;
    }

    .editorial-sidebar {
      display: none;
    }

    .mobile-rail {
      display: flex;
      gap: 8px;
      margin: 0 0 18px;
      overflow-x: auto;
      padding: 0 18px 8px;
      scrollbar-width: none;
    }

    .mobile-rail a {
      background: var(--surface);
      flex: 0 0 auto;
      font-size: 0.92rem;
      padding: 9px 12px;
      white-space: nowrap;
    }

    .editorial-main {
      padding: 0 16px;
    }

    .editorial-head h1 {
      font-size: 3rem;
    }
  }

  @media (max-width: 620px) {
    .editorial-head h1 {
      font-size: 2.25rem;
    }
  }
</style>
