---
import { categories } from "@/config/site";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";

type Props = {
  eyebrow?: string;
  title?: string;
  description?: string;
  active?: string;
};

const { eyebrow, title, description, active } = Astro.props;
const isHome = Astro.url.pathname === "/";
const discoveryLinks = [
  { label: "Today", href: isHome ? "#today" : "/#today", key: "today" },
  { label: "Trending", href: isHome ? "#trending" : "/#trending", key: "trending" },
  { label: "Recently Added", href: isHome ? "#recent" : "/#recent", key: "recent" }
];
const resourceCategoryOrder = ["models", "agents", "skills", "memory-systems", "plugins"];
const resourceLinks = resourceCategoryOrder
  .map((slug) => categories.find((category) => category.slug === slug))
  .filter((category): category is (typeof categories)[number] => Boolean(category))
  .map((category) => ({ label: category.label, href: `/${category.slug}`, key: category.slug }));
const utilityLinks = [
  { label: "Tools", href: "/tools", key: "tools" },
  { label: "Blog", href: "/blog", key: "blog" },
  { label: "Manifesto", href: "/manifesto", key: "manifesto" }
];
const sectionLinks = [...discoveryLinks, ...resourceLinks, ...utilityLinks];
---

<div class="editorial-shell">
  <aside class="editorial-sidebar" aria-label="OpenAgent.bot sections">
    <div class="sidebar-card">
      <a class="sidebar-brand" href="/" aria-label="OpenAgent.bot home">
        <span class="brand-mark">OA</span>
        <strong>OpenAgent.bot</strong>
      </a>
      <nav>
        <div class="nav-group">
          {discoveryLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
        </div>
        <div class="nav-group">
          {resourceLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
        </div>
        <div class="nav-group utility-group">
          {utilityLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
        </div>
      </nav>
    </div>
  </aside>

  <div class="editorial-main">
    <Header />
    <div class="mobile-rail" aria-label="OpenAgent.bot sections">
      {sectionLinks.map((item) => <a class:list={{ active: active === item.key }} href={item.href}>{item.label}</a>)}
    </div>
    <div class="editorial-content">
      {
        title && (
          <header class="editorial-head">
            {eyebrow && <span class="eyebrow">{eyebrow}</span>}
            <h1>{title}</h1>
            {description && <p>{description}</p>}
          </header>
        )
      }
      <slot />
      <Footer />
    </div>
  </div>
</div>

<style>
  .editorial-shell {
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr);
    min-height: 100vh;
  }

  .editorial-sidebar {
    background: color-mix(in srgb, var(--paper) 92%, white);
    border-right: 1px solid var(--line);
    height: 100vh;
    left: 0;
    overflow-y: auto;
    padding: 24px 20px;
    position: sticky;
    top: 0;
  }

  .sidebar-card {
    display: grid;
    gap: 28px;
  }

  .sidebar-brand {
    align-items: center;
    display: flex;
    gap: 10px;
    min-height: 36px;
  }

  .sidebar-brand strong {
    font-size: 1rem;
    font-weight: 650;
  }

  .brand-mark {
    align-items: center;
    background: var(--ink);
    border-radius: 8px;
    color: var(--paper);
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 700;
    height: 32px;
    justify-content: center;
    width: 32px;
  }

  nav {
    display: grid;
    gap: 15px;
  }

  .nav-group {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 3px;
    padding-bottom: 14px;
  }

  .nav-group:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  nav a,
  .mobile-rail a {
    border-radius: 8px;
    color: var(--muted);
  }

  nav a {
    font-size: 14px;
    font-weight: 400;
    padding: 8px 10px;
  }

  .utility-group {
    margin-top: 4px;
  }

  .utility-group a {
    color: var(--subtle);
    font-size: 0.86rem;
  }

  nav a:hover,
  nav a:focus-visible,
  nav a.active,
  .mobile-rail a:hover,
  .mobile-rail a.active {
    background: var(--surface);
    color: var(--ink);
    font-weight: 500;
  }

  nav a.active {
    background: var(--surface-tint);
  }

  .mobile-rail {
    display: none;
  }

  .editorial-main {
    min-width: 0;
    overflow: hidden;
    padding-top: 64px;
  }

  .editorial-content {
    margin: 0 auto;
    max-width: 1160px;
    padding: 28px 28px 64px;
  }

  .editorial-content :global([id]) {
    scroll-margin-top: 92px;
  }

  .editorial-head {
    padding: 0 0 28px;
  }

  .editorial-head h1 {
    font-size: 4rem;
    letter-spacing: 0;
    line-height: 1;
    margin: 8px 0 0;
    max-width: 900px;
  }

  .editorial-head p {
    font-size: 1.08rem;
    margin: 18px 0 0;
    max-width: 720px;
  }

  @media (max-width: 920px) {
    .editorial-shell {
      display: block;
    }

    .editorial-sidebar {
      display: none;
    }

    .mobile-rail {
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      display: flex;
      gap: 8px;
      margin: 0 0 18px;
      overflow-x: auto;
      padding: 14px 18px 10px;
      position: sticky;
      top: 64px;
      z-index: 11;
      scrollbar-width: none;
    }

    .mobile-rail a {
      background: var(--surface);
      flex: 0 0 auto;
      font-size: 0.92rem;
      padding: 9px 12px;
      white-space: nowrap;
    }

    .editorial-main {
      padding: 0;
      padding-top: 64px;
    }

    .editorial-head h1 {
      font-size: 3rem;
    }

    .editorial-head {
      padding-bottom: 22px;
    }

    .editorial-content {
      padding: 18px 16px 48px;
    }
  }

  @media (max-width: 760px) {
    .editorial-main {
      padding-top: 114px;
    }

    .mobile-rail {
      top: 114px;
    }

    .editorial-content :global([id]) {
      scroll-margin-top: 164px;
    }
  }

  @media (max-width: 620px) {
    .editorial-head h1 {
      font-size: 2.25rem;
    }
  }
</style>
