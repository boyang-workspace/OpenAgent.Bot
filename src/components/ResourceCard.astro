---
import { categories } from "@/config/site";
import type { OpenProject } from "@/lib/content/schema";

type Props = {
  resource: OpenProject;
  large?: boolean;
};

const { resource, large = false } = Astro.props;
const category = categories.find((item) => item.slug === resource.category);
const href = `/${resource.category}/${resource.slug}`;
const image = resource.coverImage ?? "/og-default.svg";
const summary = resource.oneLiner || resource.summary;
---

<article class:list={["resource-card", { large }]}>
  <a href={href} aria-label={resource.title}>
    <img src={image} alt="" loading="lazy" />
    <div class="resource-body">
      <div class="meta">
        <span>{category?.label}</span>
        {resource.license && <span>{resource.license}</span>}
      </div>
      <h3>{resource.title}</h3>
      <p>{summary}</p>
      <div class="tags">
        {resource.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </a>
</article>

<style>
  .resource-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    min-height: 100%;
    overflow: hidden;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .resource-card:hover {
    border-color: var(--line-strong);
    box-shadow: 0 8px 24px rgba(23, 25, 20, 0.04);
    transform: translateY(-2px);
  }

  a {
    display: grid;
    min-height: 100%;
  }

  img {
    aspect-ratio: 16 / 9;
    background: var(--surface-tint);
    object-fit: cover;
    width: 100%;
  }

  .resource-body {
    display: grid;
    gap: 9px;
    padding: 16px;
  }

  .meta,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .meta span {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h3 {
    font-size: 1.18rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.12;
    margin: 0;
  }

  p {
    margin: 0;
  }

  .tags span {
    background: var(--surface-soft);
    border: 1px solid transparent;
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 4px 8px;
  }

  .large a {
    grid-template-columns: minmax(0, 1.18fr) minmax(260px, 0.82fr);
  }

  .large img {
    aspect-ratio: auto;
    height: 100%;
  }

  .large .resource-body {
    align-content: center;
    padding: 34px;
  }

  .large h3 {
    font-size: 3rem;
    line-height: 1;
  }

  @media (max-width: 820px) {
    .large a {
      grid-template-columns: 1fr;
    }

    .large .resource-body {
      padding: 20px;
    }

    .large h3 {
      font-size: 1.8rem;
    }
  }
</style>
