---
import "@/styles/global.css";

type Props = {
  title: string;
  description?: string;
  active: "overview" | "review" | "projects" | "publishing" | "pages" | "blog" | "settings";
};

const nav = [
  { id: "overview", label: "Overview", href: "/admin/" },
  { id: "review", label: "Review Inbox", href: "/admin/review/" },
  { id: "projects", label: "Project Drafts", href: "/admin/projects/" },
  { id: "publishing", label: "Publishing", href: "/admin/publishing/" },
  { id: "pages", label: "Pages", href: "/admin/pages/" },
  { id: "blog", label: "Blog", href: "/admin/blog/" },
  { id: "settings", label: "Settings", href: "/admin/settings/" }
] as const;

const { title, description = "OpenAgent.bot admin", active } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · OpenAgent Admin</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="admin-body">
    <div class="admin-shell">
      <aside class="admin-sidebar" aria-label="Admin navigation">
        <a class="admin-brand" href="/admin/">
          <span>OA</span>
          <strong>OpenAgent Admin</strong>
        </a>
        <nav>
          {nav.map((item) => <a class:list={[active === item.id && "active"]} href={item.href}>{item.label}</a>)}
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/" target="_blank" rel="noreferrer">View site</a>
          <a href="/cdn-cgi/access/logout">Log out</a>
        </div>
      </aside>
      <div class="admin-workspace">
        <header class="admin-topbar">
          <div>
            <span class="eyebrow">Admin</span>
            <h1>{title}</h1>
          </div>
          <div class="admin-status">
            <span>D1 queue</span>
            <span>GitHub PR publish</span>
          </div>
        </header>
        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  .admin-body {
    background: #f7f8f4;
  }

  .admin-shell {
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr);
    min-height: 100vh;
  }

  .admin-sidebar {
    background: #ffffff;
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-height: 100vh;
    padding: 22px;
    position: sticky;
    top: 0;
  }

  .admin-brand {
    align-items: center;
    display: flex;
    gap: 10px;
  }

  .admin-brand span {
    align-items: center;
    background: var(--ink);
    border-radius: 8px;
    color: white;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 800;
    height: 38px;
    justify-content: center;
    width: 38px;
  }

  .admin-sidebar nav {
    display: grid;
    gap: 6px;
  }

  .admin-sidebar nav a,
  .admin-sidebar-footer a {
    border-radius: 8px;
    color: var(--muted);
    font-weight: 650;
    padding: 10px 12px;
  }

  .admin-sidebar nav a.active,
  .admin-sidebar nav a:hover,
  .admin-sidebar-footer a:hover {
    background: var(--surface-soft);
    color: var(--ink);
  }

  .admin-sidebar-footer {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 4px;
    margin-top: auto;
    padding-top: 16px;
  }

  .admin-workspace {
    min-width: 0;
    padding: 26px;
  }

  .admin-topbar {
    align-items: end;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    margin-bottom: 22px;
  }

  .admin-topbar h1 {
    font-size: clamp(2rem, 5vw, 4.8rem);
    line-height: 0.95;
    margin: 8px 0 0;
  }

  .admin-status {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .admin-status span,
  .status-pill {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 650;
    padding: 7px 10px;
  }

  .admin-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-soft);
    padding: 22px;
  }

  .admin-panel h2,
  .admin-panel h3 {
    margin: 0;
  }

  .admin-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .admin-grid-3 {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .admin-list {
    display: grid;
    gap: 12px;
  }

  .admin-item {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1fr) auto;
    padding: 14px;
  }

  .admin-item p {
    margin: 6px 0;
  }

  .admin-item small {
    color: var(--subtle);
    font-weight: 650;
  }

  .admin-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .admin-form {
    display: grid;
    gap: 14px;
  }

  .admin-form label {
    color: var(--muted);
    display: grid;
    font-weight: 650;
    gap: 8px;
  }

  .admin-form input,
  .admin-form select,
  .admin-form textarea {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    font: inherit;
    min-height: 42px;
    padding: 10px 12px;
  }

  .admin-form textarea {
    min-height: 104px;
    resize: vertical;
  }

  .field-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .checkbox-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .checkbox-row label {
    align-items: center;
    display: flex;
  }

  .admin-note {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    line-height: 1.55;
    padding: 14px;
  }

  .error-text,
  .form-status[data-state="error"] {
    color: var(--red);
    font-weight: 650;
  }

  .form-status[data-state="success"] {
    color: var(--green);
    font-weight: 650;
  }

  pre.admin-preview {
    background: #151713;
    border-radius: 8px;
    color: #f5f5ef;
    font-size: 0.8rem;
    max-height: 380px;
    overflow: auto;
    padding: 14px;
    white-space: pre-wrap;
  }

  @media (max-width: 900px) {
    .admin-shell {
      grid-template-columns: 1fr;
    }

    .admin-sidebar {
      min-height: auto;
      position: static;
    }

    .admin-sidebar nav {
      display: flex;
      overflow-x: auto;
    }

    .admin-grid,
    .admin-grid-3,
    .field-grid,
    .admin-item {
      grid-template-columns: 1fr;
    }
  }
</style>
