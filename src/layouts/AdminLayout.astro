---
import "@/styles/global.css";

type Props = {
  title: string;
  description?: string;
  active: "overview" | "review" | "projects" | "published" | "publishing" | "taxonomy" | "pages" | "blog" | "settings";
};

const nav = [
  { id: "overview", label: "Overview", href: "/admin/" },
  { id: "review", label: "Review Inbox", href: "/admin/review/" },
  { id: "projects", label: "Resources", href: "/admin/projects/" },
  { id: "published", label: "Published Resources", href: "/admin/published/" },
  { id: "publishing", label: "Publishing", href: "/admin/publishing/" },
  { id: "taxonomy", label: "Taxonomy", href: "/admin/taxonomy/" },
  { id: "pages", label: "Pages", href: "/admin/pages/" },
  { id: "blog", label: "Blog", href: "/admin/blog/" },
  { id: "settings", label: "Settings", href: "/admin/settings/" }
] as const;

const { title, description = "OpenAgent.bot admin", active } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · OpenAgent Admin</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="admin-body">
    <div class="admin-shell">
      <aside class="admin-sidebar" aria-label="Admin navigation">
        <a class="admin-brand" href="/admin/">
          <span>OA</span>
          <strong>OpenAgent Admin</strong>
        </a>
        <nav>
          {nav.map((item) => <a class:list={[active === item.id && "active"]} href={item.href}>{item.label}</a>)}
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/" target="_blank" rel="noreferrer">View site</a>
          <a href="/cdn-cgi/access/logout">Log out</a>
        </div>
      </aside>
      <div class="admin-workspace">
        <header class="admin-topbar">
          <div>
            <span class="eyebrow">Admin</span>
            <h1>{title}</h1>
          </div>
          <div class="admin-status">
            <span>D1 queue</span>
            <span>GitHub PR publish</span>
          </div>
        </header>
        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  .admin-body {
    background: #f6f8f3;
  }

  .admin-shell {
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr);
    min-height: 100vh;
  }

  .admin-sidebar {
    background: #ffffff;
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 24px;
    height: 100vh;
    left: 0;
    overflow-y: auto;
    padding: 20px;
    position: fixed;
    top: 0;
    width: 248px;
    z-index: 20;
  }

  .admin-brand {
    align-items: center;
    display: flex;
    gap: 10px;
  }

  .admin-brand span {
    align-items: center;
    background: var(--ink);
    border-radius: 8px;
    color: white;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 700;
    height: 38px;
    justify-content: center;
    width: 38px;
  }

  .admin-sidebar nav {
    display: grid;
    gap: 6px;
  }

  .admin-sidebar nav a,
  .admin-sidebar-footer a {
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 500;
    padding: 9px 11px;
  }

  .admin-sidebar nav a.active,
  .admin-sidebar nav a:hover,
  .admin-sidebar-footer a:hover {
    background: var(--surface-soft);
    color: var(--ink);
  }

  .admin-sidebar-footer {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 4px;
    margin-top: auto;
    padding-top: 16px;
  }

  .admin-workspace {
    grid-column: 2;
    min-width: 0;
    padding: 24px;
  }

  .admin-topbar {
    align-items: end;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .admin-topbar h1 {
    font-size: 3.4rem;
    letter-spacing: 0;
    line-height: 1;
    margin: 8px 0 0;
  }

  .admin-status {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .admin-status span,
  .status-pill {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 7px 10px;
  }

  .admin-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(23, 25, 20, 0.035);
    padding: 18px;
  }

  .admin-panel h2,
  .admin-panel h3 {
    margin: 0;
  }

  .admin-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .admin-grid-3 {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .admin-list {
    display: grid;
    gap: 12px;
  }

  .admin-item {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
    padding: 16px;
  }

  .admin-item p {
    margin: 6px 0;
  }

  .admin-item small {
    color: var(--subtle);
    font-weight: 600;
  }

  .admin-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-start;
    min-width: 0;
  }

  .admin-actions .button {
    font-size: 0.88rem;
    min-height: 38px;
    min-width: 0;
  }

  .button.danger {
    border-color: #c44a3c;
    color: #9b2d24;
  }

  .admin-form {
    display: grid;
    gap: 14px;
  }

  .admin-form-section {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 14px;
    padding: 16px;
  }

  .admin-form-section > header {
    display: grid;
    gap: 4px;
  }

  .admin-form-section h3 {
    font-size: 1.02rem;
    margin: 0;
  }

  .admin-form-section p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .admin-machine-preview {
    background: #171914;
    border-radius: 8px;
    color: #f5f5ef;
    display: grid;
    font-size: 0.84rem;
    gap: 8px;
    padding: 14px;
  }

  .admin-machine-preview code {
    color: #f5f5ef;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    overflow-wrap: anywhere;
  }

  .taxonomy-picker {
    display: grid;
    gap: 12px;
  }

  .taxonomy-picker fieldset {
    border: 1px solid var(--line);
    border-radius: 8px;
    margin: 0;
    padding: 12px;
  }

  .taxonomy-picker legend {
    color: var(--ink);
    font-size: 0.86rem;
    font-weight: 600;
    padding: 0 6px;
  }

  .taxonomy-picker fieldset > div {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .taxonomy-picker label {
    align-items: center;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.84rem;
    font-weight: 500;
    gap: 6px;
    min-height: 34px;
    padding: 6px 9px;
  }

  .taxonomy-picker input {
    min-height: 0;
    padding: 0;
  }

  .admin-form label {
    color: var(--muted);
    display: grid;
    font-weight: 600;
    gap: 8px;
  }

  .admin-form input,
  .admin-form select,
  .admin-form textarea {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    font: inherit;
    min-height: 40px;
    padding: 10px 12px;
  }

  .admin-form textarea {
    min-height: 104px;
    resize: vertical;
  }

  .field-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .checkbox-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .checkbox-row label {
    align-items: center;
    display: flex;
  }

  .admin-note {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    line-height: 1.55;
    padding: 14px;
  }

  .error-text,
  .form-status[data-state="error"] {
    color: var(--red);
    font-weight: 600;
  }

  .form-status[data-state="success"] {
    color: var(--green);
    font-weight: 600;
  }

  pre.admin-preview {
    background: #171914;
    border-radius: 8px;
    color: #f5f5ef;
    font-size: 0.8rem;
    max-height: 340px;
    overflow: auto;
    padding: 14px;
    white-space: pre-wrap;
  }

  @media (max-width: 900px) {
    .admin-shell {
      grid-template-columns: 1fr;
    }

    .admin-sidebar {
      height: auto;
      min-height: auto;
      position: static;
      width: auto;
    }

    .admin-workspace {
      grid-column: auto;
      padding: 18px;
    }

    .admin-topbar h1 {
      font-size: 2.6rem;
    }

    .admin-sidebar nav {
      display: flex;
      overflow-x: auto;
    }

    .admin-grid,
    .admin-grid-3,
    .field-grid,
    .admin-item {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .admin-topbar {
      align-items: start;
      flex-direction: column;
    }

    .admin-topbar h1 {
      font-size: 2.1rem;
    }
  }
</style>
