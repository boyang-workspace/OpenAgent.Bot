---
import ResourceCard from "@/components/ResourceCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import EditorialShell from "@/components/EditorialShell.astro";
import { categories } from "@/config/site";
import { getPublishedResources, getRelatedResources, resourceMarkdown, resourcePath } from "@/lib/content/resources";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const resources = await getPublishedResources();

  return resources.map((resource) => ({
    params: { category: resource.classification.primary_category, slug: resource.slug },
    props: { resource }
  }));
}

const { resource } = Astro.props;
const category = categories.find((item) => item.slug === resource.classification.primary_category);
const related = await getRelatedResources(resource);
const image = resource.media.og_image_url ?? resource.media.thumbnail_url ?? "/og-default.svg";
const repoLink = resource.links.items.find((link) => link.type === "github");
const homepageLink = resource.links.items.find((link) => link.type === "homepage");
const tagList = Array.from(new Set([...resource.tags.category, ...resource.tags.capability, ...resource.tags.constraint, ...resource.tags.scenario]));
const primaryCta = repoLink ?? homepageLink ?? resource.links.items[0];
const badges = [
  resource.decision_signals.open_source ? "Open source" : undefined,
  resource.facts.license,
  resource.decision_signals.supports_mcp ? "MCP" : undefined,
  resource.decision_signals.local_first ? "Local first" : undefined,
  resource.decision_signals.self_hostable ? "Self-hostable" : undefined
].filter(Boolean).slice(0, 3);
const facts = [
  { label: "Category", value: category?.label },
  { label: "Type", value: resource.classification.resource_type },
  { label: "License", value: resource.facts.license ?? "unknown" },
  { label: "Pricing", value: resource.facts.pricing_model ?? "unknown" },
  { label: "Language", value: resource.facts.primary_language },
  { label: "Stars", value: resource.facts.github_stars?.toLocaleString("en-US") },
  { label: "Forks", value: resource.facts.github_forks?.toLocaleString("en-US") },
  { label: "Repo", value: resource.facts.github_repo_full_name },
  { label: "Verified", value: resource.facts.last_verified_at?.slice(0, 10) ?? resource.timestamps.updated_at.slice(0, 10) }
].filter((item) => item.value);
const signalItems = [
  { label: "Open source", active: resource.decision_signals.open_source },
  { label: "Local first", active: resource.decision_signals.local_first },
  { label: "Self-hostable", active: resource.decision_signals.self_hostable },
  { label: "API", active: resource.decision_signals.has_api },
  { label: "CLI", active: resource.decision_signals.has_cli },
  { label: "GUI", active: resource.decision_signals.has_gui },
  { label: "MCP", active: resource.decision_signals.supports_mcp },
  { label: "Docker", active: resource.decision_signals.supports_docker }
].filter((item) => item.active);
const tagGroups = [
  { title: "Category", items: resource.tags.category },
  { title: "Capability", items: resource.tags.capability },
  { title: "Constraint", items: resource.tags.constraint },
  { title: "Scenario", items: resource.tags.scenario }
];
const relatedGroups = [
  { title: "Similar", items: resource.relationships.similar_resources },
  { title: "Alternatives", items: resource.relationships.alternatives },
  { title: "Compare with", items: resource.relationships.compare_with }
].filter((group) => group.items?.length);
const formatLabel = (value: string) => value.replaceAll("_", " ").replaceAll("-", " ");
const formatFactValue = (label: string, value: unknown) => (["Status", "Type", "Pricing"].includes(label) ? formatLabel(String(value)) : String(value));
const titleize = (value: string) => {
  const label = formatLabel(value);
  return label.charAt(0).toUpperCase() + label.slice(1);
};
const coreStrengths =
  resource.editorial?.core_strengths?.length
    ? resource.editorial.core_strengths
    : (resource.capabilities.core_capabilities ?? []).slice(0, 3).map((capability) => ({
        title: titleize(capability),
        description: `${resource.identity.name} surfaces ${formatLabel(capability)} as a core capability in its published project metadata.`,
        why_it_matters: "Use this as a starting point for evaluating fit against the official repository and docs."
      }));
const useCaseNotes =
  resource.editorial?.use_case_notes?.length
    ? resource.editorial.use_case_notes
    : (resource.positioning.use_cases ?? []).slice(0, 4).map((useCase) => ({
        title: titleize(useCase),
        description: `A relevant scenario when ${resource.identity.name}'s facts, license, and official links match your deployment needs.`
      }));
const compareNotes =
  resource.editorial?.compare_notes?.length
    ? resource.editorial.compare_notes
    : [
        {
          title: `When to choose ${resource.identity.name}`,
          summary: `Compare it with nearby ${category?.label.toLowerCase() ?? "resources"} by looking at hosting model, integrations, license, and whether the docs support your workflow.`
        }
      ];
const gettingStarted =
  resource.editorial?.getting_started?.length
    ? resource.editorial.getting_started
    : resource.links.items
        .filter((link) => ["github", "docs", "demo", "install", "api_reference", "homepage"].includes(link.type))
        .slice(0, 5)
        .map((link) => ({ label: link.label, url: link.url, type: link.type }));
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: resource.identity.name,
  description: resource.identity.short_description ?? resource.identity.one_liner,
  codeRepository: repoLink?.url,
  url: homepageLink?.url ?? repoLink?.url ?? resource.links.primary_url,
  license: resource.facts.license,
  programmingLanguage: resource.facts.primary_language ?? resource.capabilities.integrations?.join(", "),
  keywords: tagList.join(", ")
};
---

<BaseLayout
  title={resource.seo?.title ?? resource.identity.name}
  description={resource.seo?.description ?? resource.identity.short_description ?? resource.identity.one_liner}
  path={resourcePath(resource)}
  image={image}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <EditorialShell active={resource.classification.primary_category}>
    <article class="resource-hero">
      <div class="hero-media">
        <img src={image} alt="" />
      </div>
      <div class="hero-copy">
        <span class="eyebrow">{category?.label}</span>
        <h1>{resource.identity.name}</h1>
        <p class="one-liner">{resource.identity.one_liner}</p>
        {resource.identity.short_description && <p class="summary">{resource.identity.short_description}</p>}
        <div class="badges">
          {badges.map((badge) => <span>{badge}</span>)}
        </div>
        <div class="actions">
          {primaryCta && <a class="button" href={primaryCta.url}>{primaryCta.type === "github" ? "View repository" : primaryCta.label}</a>}
          {homepageLink && homepageLink.url !== primaryCta?.url && <a class="button secondary" href={homepageLink.url}>Homepage</a>}
          <a class="button secondary" href={resource.machine_readable.json_url.replace("https://www.openagent.bot", "")}>JSON</a>
          <a class="button secondary" href={resource.machine_readable.markdown_url.replace("https://www.openagent.bot", "")}>Markdown</a>
        </div>
      </div>
    </article>

    <section class="profile-grid">
      <div class="profile-main">
        <section class="panel narrative-panel">
          <span class="eyebrow">Why this matters</span>
          <h2>{resource.identity.name} in context</h2>
          <p>{resource.positioning.why_it_matters ?? resource.identity.short_description ?? resource.identity.one_liner}</p>
        </section>

        <section class="panel decision-panel">
          <span class="eyebrow">Decision guide</span>
          <h2>Is it a fit?</h2>
          <div class="decision-grid">
            <div>
              <h3>Best for</h3>
              <ul class="check-list">
                {(resource.positioning.best_for ?? ["Teams evaluating this category of open AI resource."]).map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <h3>Not for</h3>
              <ul class="check-list muted-list">
                {(resource.positioning.not_for ?? ["Use cases where the linked source, license, or deployment model does not match your requirements."]).map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </section>

        <section class="panel">
          <span class="eyebrow">What it actually does</span>
          <h2>Core strengths</h2>
          <div class="story-grid">
            {
              coreStrengths.map((item) => (
                <div class="story-card">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                  {item.why_it_matters && <small>{item.why_it_matters}</small>}
                </div>
              ))
            }
          </div>
        </section>

        <section class="panel">
          <span class="eyebrow">Typical use cases</span>
          <h2>Where it fits</h2>
          <div class="use-case-list">
            {useCaseNotes.map((item) => (
              <article>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="panel compare-panel">
          <span class="eyebrow">How it compares</span>
          <h2>Selection notes</h2>
          <div class="compare-list">
            {compareNotes.map((item) => (
              <article>
                <h3>{item.title}</h3>
                {item.against && <small>Against {item.against}</small>}
                <p>{item.summary}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="panel">
          <span class="eyebrow">Getting started</span>
          <h2>Next official steps</h2>
          <div class="start-list">
            {gettingStarted.map((link) => (
              <a href={link.url}>
                <span>{formatLabel(link.type)}</span>
                <strong>{link.label}</strong>
              </a>
            ))}
          </div>
        </section>

        <section class="panel">
          <span class="eyebrow">Links</span>
          <h2>Source and docs</h2>
          <div class="link-list">
            {
              resource.links.items.map((link) => (
                <a href={link.url}>
                  <span>{formatLabel(link.type)}</span>
                  <strong>{link.label}</strong>
                  <small>{link.url}</small>
                </a>
              ))
            }
          </div>
        </section>

        {
          relatedGroups.length > 0 && (
            <section class="panel">
              <span class="eyebrow">Relationships</span>
              <h2>Nearby resources</h2>
              <div class="capability-grid">
                {relatedGroups.map((group) => (
                  <div class="mini-panel">
                    <h3>{group.title}</h3>
                  <div class="chip-row">
                    {group.items?.map((item) => <span>{item}</span>)}
                  </div>
                </div>
              ))}
              </div>
            </section>
          )
        }

        <section class="panel agent-panel">
          <div class="panel-head">
            <div>
              <span class="eyebrow">Agent-readable</span>
              <h2>Stable machine outputs</h2>
            </div>
            <div class="agent-actions">
              <a href={resource.machine_readable.json_url.replace("https://www.openagent.bot", "")}>JSON</a>
              <a href={resource.machine_readable.markdown_url.replace("https://www.openagent.bot", "")}>Markdown</a>
            </div>
          </div>
          <div class="tag-groups">
            {
              tagGroups.map((group) => (
                <div>
                  <h3>{group.title}</h3>
                  <div class="chip-row">
                    {group.items.slice(0, 5).map((tag) => <span>{formatLabel(tag)}</span>)}
                  </div>
                </div>
              ))
            }
          </div>
          <pre><code>{resourceMarkdown(resource).slice(0, 760)}</code></pre>
        </section>
      </div>

      <aside class="source-panel">
        <span class="eyebrow">Facts</span>
        <h2>At a glance</h2>
        <dl>
          <div>
            <dt>Status</dt>
            <dd>{resource.status}</dd>
          </div>
          {facts.map((fact) => (
            <div>
              <dt>{fact.label}</dt>
              <dd>{formatFactValue(fact.label, fact.value)}</dd>
            </div>
          ))}
        </dl>

        {
          signalItems.length > 0 && (
            <div class="signals">
              <h3>Signals</h3>
              <div class="chip-row">
                {signalItems.map((item) => <span>{item.label}</span>)}
              </div>
            </div>
          )
        }

        <div class="signals">
          <h3>Tags</h3>
          <div class="chip-row">
            {tagList.slice(0, 12).map((tag) => <span>{formatLabel(tag)}</span>)}
          </div>
        </div>
      </aside>
    </section>

    {
      related.length > 0 && (
        <section class="section">
          <SectionHeading eyebrow="Related" title={`More ${category?.label.toLowerCase()}`} />
          <div class="grid grid-3">
            {related.map((item) => <ResourceCard resource={item} />)}
          </div>
        </section>
      )
    }
  </EditorialShell>
</BaseLayout>

<style>
  .resource-hero {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-feature);
    display: grid;
    gap: 0;
    grid-template-columns: minmax(220px, 0.48fr) minmax(0, 1.52fr);
    overflow: hidden;
  }

  .hero-media {
    background: var(--surface-tint);
    border-right: 1px solid var(--line);
    min-height: 100%;
  }

  .hero-media img {
    aspect-ratio: 4 / 5;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .hero-copy {
    align-content: center;
    display: grid;
    min-width: 0;
    padding: 34px;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.15rem);
    letter-spacing: 0;
    line-height: 1;
    margin: 10px 0 0;
  }

  .one-liner {
    color: var(--ink);
    font-size: 1.16rem;
    font-weight: 650;
    line-height: 1.42;
    margin: 18px 0 0;
  }

  .summary {
    font-size: 1rem;
    margin: 12px 0 0;
    max-width: 760px;
  }

  .badges,
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badges {
    margin-top: 20px;
  }

  .badges span,
  .chip-row span {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.2;
    padding: 6px 9px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .secondary {
    border-color: var(--line);
  }

  .profile-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    margin-top: 34px;
  }

  .profile-main {
    display: grid;
    gap: 22px;
  }

  .panel,
  .source-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px;
  }

  .panel h2,
  .source-panel h2 {
    font-size: 1.58rem;
    letter-spacing: 0;
    line-height: 1.12;
    margin: 8px 0 0;
  }

  .panel h3,
  .source-panel h3 {
    font-size: 0.96rem;
    letter-spacing: 0;
    margin: 0 0 10px;
  }

  .narrative-panel p {
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.72;
    margin: 18px 0 0;
    max-width: 780px;
  }

  .decision-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .decision-grid > div,
  .story-card,
  .use-case-list article,
  .compare-list article {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
  }

  .story-grid {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }

  .story-card p,
  .use-case-list p,
  .compare-list p {
    margin: 0;
  }

  .story-card h3,
  .use-case-list h3,
  .compare-list h3 {
    margin-bottom: 8px;
  }

  .story-card small,
  .compare-list small {
    color: var(--muted);
    display: block;
    font-size: 0.88rem;
    line-height: 1.5;
    margin-top: 10px;
  }

  .use-case-list,
  .compare-list {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }

  .start-list {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .start-list a {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 4px;
    padding: 14px;
  }

  .start-list span {
    color: var(--accent-open);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .judgment-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 0.95fr) minmax(260px, 1.05fr);
    margin-top: 18px;
  }

  .judgment-primary {
    background: var(--surface-tint);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 18px;
  }

  .judgment-primary h2 {
    margin-top: 0;
  }

  .judgment-primary p {
    color: var(--ink);
    margin-bottom: 0;
  }

  .judgment-lists {
    display: grid;
    gap: 18px;
  }

  .check-list {
    display: grid;
    gap: 9px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .check-list li {
    color: var(--muted);
    line-height: 1.45;
    padding-left: 18px;
    position: relative;
  }

  .check-list li::before {
    background: var(--accent-open);
    border-radius: 999px;
    content: "";
    height: 6px;
    left: 0;
    position: absolute;
    top: 0.65em;
    width: 6px;
  }

  .muted-list li::before {
    background: var(--subtle);
  }

  .capability-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .mini-panel {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
  }

  .link-list {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }

  .link-list a {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 4px;
    min-width: 0;
    padding: 14px;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .link-list a:hover {
    background: var(--surface-soft);
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }

  .link-list span {
    color: var(--accent-open);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .link-list strong {
    font-size: 1.02rem;
    line-height: 1.2;
  }

  .link-list small {
    color: var(--muted);
    overflow-wrap: anywhere;
  }

  .panel-head {
    align-items: start;
    display: flex;
    gap: 16px;
    justify-content: space-between;
  }

  .agent-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .agent-actions a {
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 8px 10px;
  }

  .tag-groups {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .tag-groups > div {
    min-width: 0;
  }

  pre {
    background: #171914;
    border-radius: 8px;
    color: #f6f8f2;
    font-size: 0.82rem;
    line-height: 1.55;
    margin: 18px 0 0;
    overflow: auto;
    padding: 16px;
    white-space: pre-wrap;
  }

  .source-panel {
    align-self: start;
    position: sticky;
    top: 96px;
  }

  .source-panel dl {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0;
    margin: 18px 0 0;
  }

  .source-panel dl div {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 8px;
    grid-template-columns: 108px minmax(0, 1fr);
    padding: 12px 0;
  }

  dt {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  dd {
    line-height: 1.35;
    margin: 0;
    overflow-wrap: anywhere;
  }

  .signals {
    border-top: 1px solid var(--line);
    margin-top: 18px;
    padding-top: 18px;
  }

  @media (max-width: 860px) {
    .resource-hero,
    .profile-grid {
      grid-template-columns: 1fr;
    }

    .hero-media {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .hero-copy {
      padding: 22px;
    }

    .judgment-grid,
    .decision-grid,
    .capability-grid,
    .start-list,
    .tag-groups {
      grid-template-columns: 1fr;
    }

    .source-panel {
      position: static;
    }
  }

  @media (max-width: 620px) {
    .panel,
    .source-panel {
      padding: 18px;
    }

    .panel-head {
      display: grid;
    }

    .source-panel dl div {
      grid-template-columns: 1fr;
    }

    .actions {
      display: grid;
    }

    .button {
      width: 100%;
    }
  }
</style>
