---
import ResourceCard from "@/components/ResourceCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import EditorialShell from "@/components/EditorialShell.astro";
import { categories } from "@/config/site";
import { getPublishedResources, getRelatedResources, resourceMarkdown, resourcePath } from "@/lib/content/resources";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const resources = await getPublishedResources();

  return resources.map((resource) => ({
    params: { category: resource.classification.primary_category, slug: resource.slug },
    props: { resource }
  }));
}

const { resource } = Astro.props;
const category = categories.find((item) => item.slug === resource.classification.primary_category);
const related = await getRelatedResources(resource);
const image = resource.media.og_image_url ?? resource.media.thumbnail_url ?? "/og-default.svg";
const repoLink = resource.links.items.find((link) => link.type === "github");
const homepageLink = resource.links.items.find((link) => link.type === "homepage");
const tagList = Array.from(new Set([...resource.tags.category, ...resource.tags.capability, ...resource.tags.constraint, ...resource.tags.scenario]));
const primaryCta = repoLink ?? homepageLink ?? resource.links.items[0];
const badges = [
  resource.decision_signals.open_source ? "Open source" : undefined,
  resource.facts.license,
  resource.decision_signals.supports_mcp ? "MCP" : undefined,
  resource.decision_signals.local_first ? "Local first" : undefined,
  resource.decision_signals.self_hostable ? "Self-hostable" : undefined
].filter(Boolean).slice(0, 3);
const facts = [
  { label: "Category", value: category?.label },
  { label: "Type", value: resource.classification.resource_type },
  { label: "License", value: resource.facts.license ?? "unknown" },
  { label: "Language", value: resource.facts.primary_language },
  { label: "Stars", value: resource.facts.github_stars?.toLocaleString("en-US") },
  { label: "Forks", value: resource.facts.github_forks?.toLocaleString("en-US") },
  { label: "Repo", value: resource.facts.github_repo_full_name },
  { label: "Verified", value: resource.facts.last_verified_at?.slice(0, 10) ?? resource.timestamps.updated_at.slice(0, 10) }
].filter((item) => item.value);
const signalItems = [
  { label: "Open source", active: resource.decision_signals.open_source },
  { label: "Local first", active: resource.decision_signals.local_first },
  { label: "Self-hostable", active: resource.decision_signals.self_hostable },
  { label: "API", active: resource.decision_signals.has_api },
  { label: "CLI", active: resource.decision_signals.has_cli },
  { label: "GUI", active: resource.decision_signals.has_gui },
  { label: "MCP", active: resource.decision_signals.supports_mcp },
  { label: "Docker", active: resource.decision_signals.supports_docker }
].filter((item) => item.active);
const tagGroups = [
  { title: "Category", items: resource.tags.category },
  { title: "Capability", items: resource.tags.capability },
  { title: "Constraint", items: resource.tags.constraint },
  { title: "Scenario", items: resource.tags.scenario }
];
const relatedGroups = [
  { title: "Similar", items: resource.relationships.similar_resources },
  { title: "Alternatives", items: resource.relationships.alternatives },
  { title: "Compare with", items: resource.relationships.compare_with }
].filter((group) => group.items?.length);
const formatLabel = (value: string) => value.replaceAll("_", " ").replaceAll("-", " ");
const formatFactValue = (label: string, value: unknown) => (["Status", "Type", "Pricing"].includes(label) ? formatLabel(String(value)) : String(value));
const titleize = (value: string) => {
  const label = formatLabel(value);
  return label.charAt(0).toUpperCase() + label.slice(1);
};
const useCaseNotes =
  resource.editorial?.use_case_notes?.length
    ? resource.editorial.use_case_notes
    : (resource.positioning.use_cases ?? []).slice(0, 4).map((useCase) => ({
        title: titleize(useCase),
        description: `A relevant scenario when ${resource.identity.name}'s facts, license, and official links match your deployment needs.`
      }));
const compareNotes =
  resource.editorial?.compare_notes?.length
    ? resource.editorial.compare_notes
    : [
        {
          title: `When to choose ${resource.identity.name}`,
          summary: `Compare it with nearby ${category?.label.toLowerCase() ?? "resources"} by looking at hosting model, integrations, license, and whether the docs support your workflow.`
        }
      ];
const gettingStarted =
  resource.editorial?.getting_started?.length
    ? resource.editorial.getting_started
    : resource.links.items
        .filter((link) => ["github", "docs", "demo", "install", "api_reference", "homepage"].includes(link.type))
        .slice(0, 5)
        .map((link) => ({ label: link.label, url: link.url, type: link.type }));
const seoArticle = resource.editorial?.seo_article;
const articleGettingStarted = seoArticle?.getting_started?.length ? seoArticle.getting_started : gettingStarted;
const commandLine = resource.editorial?.command_line ?? [];
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: resource.identity.name,
  description: resource.identity.short_description ?? resource.identity.one_liner,
  codeRepository: repoLink?.url,
  url: homepageLink?.url ?? repoLink?.url ?? resource.links.primary_url,
  license: resource.facts.license,
  programmingLanguage: resource.facts.primary_language ?? resource.capabilities.integrations?.join(", "),
  keywords: tagList.join(", ")
};
---

<BaseLayout
  title={resource.seo?.title ?? resource.identity.name}
  description={resource.seo?.description ?? resource.identity.short_description ?? resource.identity.one_liner}
  path={resourcePath(resource)}
  image={image}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <EditorialShell active={resource.classification.primary_category}>
    <article class="resource-hero">
      <div class="hero-copy">
        <span class="eyebrow">{category?.label}</span>
        <h1>{resource.identity.name}</h1>
        <p class="one-liner">{resource.identity.one_liner}</p>
        {resource.identity.short_description && <p class="summary">{resource.identity.short_description}</p>}
        <div class="badges">
          {badges.map((badge) => <span>{badge}</span>)}
        </div>
        <div class="actions">
          {primaryCta && <a class="button" href={primaryCta.url}>{primaryCta.type === "github" ? "View repository" : primaryCta.label}<span class="new-window-icon" aria-hidden="true"></span></a>}
          {homepageLink && homepageLink.url !== primaryCta?.url && <a class="button secondary" href={homepageLink.url}>Homepage<span class="new-window-icon" aria-hidden="true"></span></a>}
          <a class="button secondary" href="#technical-profile">Technical profile</a>
        </div>
      </div>
    </article>

    <section class="human-detail">
      <section class="panel overview-panel">
        <span class="eyebrow">Overview</span>
        <h2>{resource.identity.name}: what to know first</h2>
        <div class="prose-flow">
          {seoArticle?.intro && <p>{seoArticle.intro}</p>}
          {seoArticle?.what_it_is && <p>{seoArticle.what_it_is}</p>}
          {seoArticle?.why_it_matters && <p>{seoArticle.why_it_matters}</p>}
        </div>
      </section>

      <section class="panel use-panel">
        <span class="eyebrow">Use cases</span>
        <h2>Common ways to use it</h2>
        <div class="human-list">
          {useCaseNotes.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="panel decision-panel">
        <span class="eyebrow">Fit guide</span>
        <h2>When it makes sense</h2>
        <div class="try-grid">
          <div>
            <h3>Good fit if</h3>
            <ul class="check-list">
              {(resource.positioning.best_for ?? ["Teams evaluating this category of open AI resource."]).map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div>
            <h3>Not a fit if</h3>
            <ul class="check-list muted-list">
              {(resource.positioning.not_for ?? ["Use cases where the linked source, license, or deployment model does not match your requirements."]).map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="compare-note">
            <h3>How to choose</h3>
            {compareNotes.slice(0, 2).map((item) => (
              <p>
                <strong>{item.title}</strong>
                {item.against ? ` vs ${item.against}: ` : ": "}
                {item.summary}
              </p>
            ))}
          </div>
        </div>
      </section>

      <section class="panel next-panel">
        <span class="eyebrow">Next step</span>
        <h2>Where to go from here</h2>
        <div class="start-list">
          {articleGettingStarted.map((link) => (
            <a href={link.url}>
              <span>{formatLabel(link.type)}</span>
              <strong>{link.label}<i class="new-window-icon" aria-hidden="true"></i></strong>
            </a>
          ))}
        </div>
      </section>

      {
        commandLine.length > 0 && (
          <section class="panel command-panel">
            <span class="eyebrow">Try it locally</span>
            <h2>Command line</h2>
            <div class="command-list">
              {commandLine.map((item) => (
                <article>
                  <div>
                    <h3>{item.label}</h3>
                    {item.description && <p>{item.description}</p>}
                  </div>
                  <pre><code>{item.command}</code></pre>
                </article>
              ))}
            </div>
          </section>
        )
      }

      <details id="technical-profile" class="technical-profile">
        <summary>
          <span>
            <span class="eyebrow">Technical details</span>
            <strong>Structured profile</strong>
          </span>
          <em>Facts and source data</em>
        </summary>

        <div class="technical-grid">
          <section class="source-panel">
            <h2>At a glance</h2>
            <dl>
              <div>
                <dt>Status</dt>
                <dd>{resource.status}</dd>
              </div>
              {facts.map((fact) => (
                <div>
                  <dt>{fact.label}</dt>
                  <dd>{formatFactValue(fact.label, fact.value)}</dd>
                </div>
              ))}
            </dl>

            {
              signalItems.length > 0 && (
                <div class="signals">
                  <h3>Signals</h3>
                  <div class="chip-row">
                    {signalItems.map((item) => <span>{item.label}</span>)}
                  </div>
                </div>
              )
            }
          </section>

          <section class="source-panel">
            <h2>Tags</h2>
            <div class="tag-groups compact">
              {
                tagGroups.map((group) => (
                  <div>
                    <h3>{group.title}</h3>
                    <div class="chip-row">
                      {group.items.slice(0, 5).map((tag) => <span>{formatLabel(tag)}</span>)}
                    </div>
                  </div>
                ))
              }
            </div>
          </section>

          <section class="source-panel wide-panel">
            <div class="panel-head">
              <div>
                <h2>Structured outputs</h2>
              </div>
              <div class="agent-actions">
                <a href={resource.machine_readable.json_url.replace("https://www.openagent.bot", "")}>JSON</a>
                <a href={resource.machine_readable.markdown_url.replace("https://www.openagent.bot", "")}>Markdown</a>
              </div>
            </div>
            <pre><code>{resourceMarkdown(resource).slice(0, 760)}</code></pre>
          </section>

          <section class="source-panel wide-panel">
            <h2>Source links</h2>
            <div class="link-list">
              {
                resource.links.items.map((link) => (
                  <a href={link.url}>
                    <span>{formatLabel(link.type)}</span>
                    <strong>{link.label}</strong>
                    <small>{link.url}</small>
                  </a>
                ))
              }
            </div>
          </section>

          {
            relatedGroups.length > 0 && (
              <section class="source-panel wide-panel">
                <h2>Relationships</h2>
                <div class="capability-grid">
                  {relatedGroups.map((group) => (
                    <div class="mini-panel">
                      <h3>{group.title}</h3>
                      <div class="chip-row">
                        {group.items?.map((item) => <span>{item}</span>)}
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            )
          }
        </div>
      </details>
    </section>

    {
      related.length > 0 && (
        <section class="section">
          <SectionHeading eyebrow="Related" title={`More ${category?.label.toLowerCase()}`} />
          <div class="grid grid-3">
            {related.map((item) => <ResourceCard resource={item} />)}
          </div>
        </section>
      )
    }
  </EditorialShell>
</BaseLayout>

<style>
  .resource-hero {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-feature);
  }

  .hero-copy {
    align-content: center;
    display: grid;
    min-width: 0;
    padding: 28px 32px 30px;
  }

  h1 {
    font-size: clamp(2.15rem, 4.2vw, 3.35rem);
    letter-spacing: 0;
    line-height: 1.02;
    margin: 10px 0 0;
  }

  .one-liner {
    color: var(--ink);
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.42;
    margin: 14px 0 0;
  }

  .summary {
    font-size: 0.92rem;
    margin: 10px 0 0;
    max-width: 760px;
  }

  .badges,
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badges {
    margin-top: 20px;
  }

  .badges span,
  .chip-row span {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 500;
    line-height: 1.2;
    padding: 5px 8px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }

  .actions .button {
    font-size: 0.84rem;
    min-height: 36px;
    padding: 0 13px;
  }

  .new-window-icon {
    background: #a8afa5;
    display: inline-block;
    height: 0.86em;
    margin-left: 2px;
    mask: url("/external-link.svg") center / contain no-repeat;
    width: 0.86em;
  }

  .secondary {
    border-color: var(--line);
  }

  .profile-grid {
    display: grid;
    gap: 30px;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
    margin-top: 30px;
  }

  .human-detail {
    margin-top: 28px;
    max-width: 920px;
  }

  .profile-main {
    display: grid;
    gap: 0;
  }

  .panel {
    border-top: 1px solid var(--line);
    padding: 24px 0;
  }

  .profile-main .panel:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .human-detail > .panel:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .source-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
  }

  .panel h2,
  .source-panel h2 {
    font-size: 1.34rem;
    letter-spacing: 0;
    line-height: 1.18;
    margin: 8px 0 0;
  }

  .source-panel h2 {
    font-size: 1.05rem;
  }

  .panel h3,
  .source-panel h3 {
    font-size: 0.88rem;
    letter-spacing: 0;
    margin: 0 0 10px;
  }

  .narrative-panel p {
    color: var(--ink);
    font-size: 0.96rem;
    line-height: 1.68;
    margin: 14px 0 0;
    max-width: 780px;
  }

  .article-panel h2 {
    max-width: 780px;
  }

  .article-lead,
  .article-sections p {
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.72;
    margin: 12px 0 0;
    max-width: 760px;
  }

  .article-lead {
    font-size: 1rem;
  }

  .article-sections {
    display: grid;
    gap: 22px;
    margin-top: 24px;
  }

  .article-sections section {
    border-top: 1px solid var(--line);
    padding-top: 18px;
  }

  .article-list {
    display: grid;
    gap: 12px;
    margin-top: 12px;
  }

  .article-list article {
    border-top: 1px solid var(--line);
    padding-top: 12px;
  }

  .article-list article:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .article-list strong {
    display: block;
    font-size: 0.92rem;
    line-height: 1.3;
  }

  .article-list small {
    color: var(--muted);
    display: block;
    font-size: 0.76rem;
    margin-top: 4px;
  }

  .prose-flow {
    display: grid;
    gap: 14px;
    margin-top: 18px;
    max-width: 760px;
  }

  .prose-flow p {
    color: var(--ink);
    font-size: 0.96rem;
    line-height: 1.74;
    margin: 0;
  }

  .human-list {
    display: grid;
    gap: 0;
    margin-top: 18px;
  }

  .human-list article {
    border-top: 1px solid var(--line);
    padding: 15px 0;
  }

  .human-list article:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .human-list h3 {
    margin-bottom: 7px;
  }

  .human-list p {
    font-size: 0.92rem;
    line-height: 1.62;
    margin: 0;
    max-width: 740px;
  }

  .decision-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 16px;
  }

  .try-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .try-grid > div {
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .try-grid .compare-note {
    grid-column: 1 / -1;
  }

  .compare-note p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.62;
    margin: 0 0 10px;
    max-width: 780px;
  }

  .compare-note strong {
    color: var(--ink);
  }

  .command-list {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }

  .command-list article {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 14px;
    padding-top: 15px;
  }

  .command-list article:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .command-list p {
    font-size: 0.9rem;
    line-height: 1.58;
    margin: 0;
    max-width: 720px;
  }

  .command-list pre {
    background: #171914;
    border-radius: 8px;
    color: #f7f8f4;
    font-size: 0.82rem;
    line-height: 1.55;
    margin: 0;
    overflow-x: auto;
    padding: 13px 14px;
  }

  .decision-grid > div,
  .story-card,
  .use-case-list article,
  .compare-list article {
    border-top: 1px solid var(--line);
    padding: 14px 0 0;
  }

  .decision-grid > div {
    border-top: 0;
    padding-top: 0;
  }

  .story-grid {
    display: grid;
    gap: 16px;
    margin-top: 16px;
  }

  .story-card:first-child,
  .use-case-list article:first-child,
  .compare-list article:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .story-card p,
  .use-case-list p,
  .compare-list p {
    font-size: 0.9rem;
    line-height: 1.58;
    margin: 0;
  }

  .story-card h3,
  .use-case-list h3,
  .compare-list h3 {
    margin-bottom: 8px;
  }

  .story-card small,
  .compare-list small {
    color: var(--muted);
    display: block;
    font-size: 0.78rem;
    line-height: 1.5;
    margin-top: 8px;
  }

  .use-case-list,
  .compare-list {
    display: grid;
    gap: 14px;
    margin-top: 16px;
  }

  .start-list {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .start-list a {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 4px;
    padding: 12px;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .start-list a:hover {
    background: var(--surface);
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }

  .start-list span {
    color: var(--accent-open);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .start-list strong {
    align-items: center;
    display: inline-flex;
    gap: 5px;
  }

  .judgment-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 0.95fr) minmax(260px, 1.05fr);
    margin-top: 18px;
  }

  .judgment-primary {
    background: var(--surface-tint);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 18px;
  }

  .judgment-primary h2 {
    margin-top: 0;
  }

  .judgment-primary p {
    color: var(--ink);
    margin-bottom: 0;
  }

  .judgment-lists {
    display: grid;
    gap: 18px;
  }

  .check-list {
    display: grid;
    gap: 9px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .check-list li {
    color: var(--muted);
    line-height: 1.45;
    padding-left: 18px;
    position: relative;
  }

  .check-list li::before {
    background: var(--accent-open);
    border-radius: 999px;
    content: "";
    height: 6px;
    left: 0;
    position: absolute;
    top: 0.65em;
    width: 6px;
  }

  .muted-list li::before {
    background: var(--subtle);
  }

  .capability-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .mini-panel {
    border-top: 1px solid var(--line);
    padding: 12px 0 0;
  }

  .link-list {
    display: grid;
    gap: 0;
    margin-top: 16px;
  }

  .link-list a {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 4px;
    min-width: 0;
    padding: 12px 0;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .link-list a:hover {
    background: var(--surface-soft);
    border-color: var(--line);
    transform: translateY(-1px);
  }

  .link-list span {
    color: var(--accent-open);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .link-list strong {
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .link-list small {
    color: var(--muted);
    overflow-wrap: anywhere;
  }

  .panel-head {
    align-items: start;
