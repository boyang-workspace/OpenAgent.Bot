---
import ResourceCard from "@/components/ResourceCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import EditorialShell from "@/components/EditorialShell.astro";
import { categories } from "@/config/site";
import { getPublishedResources, getRelatedResources, resourceMarkdown, resourcePath } from "@/lib/content/resources";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const resources = await getPublishedResources();

  return resources.map((resource) => ({
    params: { category: resource.classification.primary_category, slug: resource.slug },
    props: { resource }
  }));
}

const { resource } = Astro.props;
const category = categories.find((item) => item.slug === resource.classification.primary_category);
const related = await getRelatedResources(resource);
const image = resource.media.og_image_url ?? resource.media.thumbnail_url ?? "/og-default.svg";
const repoLink = resource.links.items.find((link) => link.type === "github");
const homepageLink = resource.links.items.find((link) => link.type === "homepage");
const tagList = Array.from(new Set([...resource.tags.category, ...resource.tags.capability, ...resource.tags.constraint, ...resource.tags.scenario]));
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: resource.identity.name,
  description: resource.identity.short_description ?? resource.identity.one_liner,
  codeRepository: repoLink?.url,
  url: homepageLink?.url ?? repoLink?.url ?? resource.links.primary_url,
  license: resource.facts.license,
  programmingLanguage: resource.facts.primary_language ?? resource.capabilities.integrations?.join(", "),
  keywords: tagList.join(", ")
};
---

<BaseLayout
  title={resource.seo?.title ?? resource.identity.name}
  description={resource.seo?.description ?? resource.identity.short_description ?? resource.identity.one_liner}
  path={resourcePath(resource)}
  image={image}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <EditorialShell active={resource.classification.primary_category}>
    <article class="detail">
      <div class="detail-copy">
        <span class="eyebrow">{category?.label}</span>
        <h1>{resource.identity.name}</h1>
        <p class="one-liner">{resource.identity.one_liner}</p>
        <p>{resource.identity.short_description}</p>
        <div class="actions">
          {repoLink && <a class="button" href={repoLink.url}>Repository</a>}
          {homepageLink && <a class="button secondary" href={homepageLink.url}>Homepage</a>}
          <a class="button secondary" href={resource.machine_readable.json_url.replace("https://www.openagent.bot", "")}>JSON</a>
          <a class="button secondary" href={resource.machine_readable.markdown_url.replace("https://www.openagent.bot", "")}>Markdown</a>
        </div>
      </div>
      <img src={image} alt="" />
    </article>

    <section class="profile-grid">
      <div class="profile-main">
        <section>
          <h2>Why it matters</h2>
          <p>{resource.positioning.why_it_matters}</p>
        </section>

        <section>
          <h2>Best for</h2>
          <ul>
            {(resource.positioning.best_for ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </section>

        {
          resource.positioning.not_for && resource.positioning.not_for.length > 0 && (
            <section>
              <h2>Not for</h2>
              <ul>
                {resource.positioning.not_for.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          )
        }

        {
          resource.links.items.some((link) => link.type === "install") && (
            <section>
              <h2>How to try</h2>
              <ul>
                {resource.links.items.filter((link) => link.type === "install").map((link) => <li><a href={link.url}>{link.label}</a></li>)}
              </ul>
            </section>
          )
        }

        <section>
          <h2>Agent-readable preview</h2>
          <pre><code>{resourceMarkdown(resource).slice(0, 900)}</code></pre>
        </section>
      </div>

      <aside class="source-panel">
        <h2>Project facts</h2>
        <dl>
          <div>
            <dt>Category</dt>
            <dd>{category?.label}</dd>
          </div>
          <div>
            <dt>License</dt>
            <dd>{resource.facts.license ?? "unknown"}</dd>
          </div>
          <div>
            <dt>Updated</dt>
            <dd>{resource.timestamps.updated_at.slice(0, 10)}</dd>
          </div>
          <div>
            <dt>Open source</dt>
            <dd>{resource.decision_signals.open_source ? "yes" : "unknown"}</dd>
          </div>
          <div>
            <dt>Tags</dt>
            <dd>{tagList.slice(0, 12).join(", ")}</dd>
          </div>
        </dl>

        <h2>Source links</h2>
        <ul>
          {resource.links.items.map((link) => <li><a href={link.url}>{link.label}</a></li>)}
        </ul>
      </aside>
    </section>

    {
      related.length > 0 && (
        <section class="section">
          <SectionHeading eyebrow="Related" title={`More ${category?.label.toLowerCase()}`} />
          <div class="grid grid-3">
            {related.map((item) => <ResourceCard resource={item} />)}
          </div>
        </section>
      )
    }
  </EditorialShell>
</BaseLayout>

<style>
  .detail {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-feature);
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    overflow: hidden;
    padding: 26px;
  }

  h1 {
    font-size: 4.3rem;
    letter-spacing: 0;
    line-height: 1;
    margin: 10px 0 0;
  }

  .detail-copy p {
    font-size: 1.04rem;
  }

  .one-liner {
    color: var(--ink);
    font-weight: 650;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .secondary {
    border-color: var(--line);
  }

  .detail img {
    aspect-ratio: 16 / 10;
    border-radius: 8px;
    object-fit: cover;
    width: 100%;
  }

  .profile-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
    margin-top: 34px;
  }

  .profile-main {
    display: grid;
    gap: 22px;
  }

  .profile-main section,
  .source-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 18px;
  }

  .profile-main h2,
  .source-panel h2 {
    font-size: 1.5rem;
    letter-spacing: 0;
    margin: 0 0 10px;
  }

  ul {
    margin: 0;
    padding-left: 20px;
  }

  li + li {
    margin-top: 8px;
  }

  pre {
    background: #171914;
    border-radius: 8px;
    color: #f6f8f2;
    font-size: 0.88rem;
    overflow: auto;
    padding: 16px;
    white-space: pre-wrap;
  }

  .source-panel {
    align-self: start;
    position: sticky;
    top: 92px;
  }

  .source-panel dl {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0;
    margin: 0;
  }

  .source-panel div {
    border-top: 1px solid var(--line);
    padding: 14px 0;
  }

  dt {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  dd {
    margin: 8px 0 0;
  }

  @media (max-width: 860px) {
    .detail,
    .profile-grid {
      grid-template-columns: 1fr;
    }

    .detail {
      padding: 18px;
    }

    h1 {
      font-size: 3rem;
    }

    .source-panel {
      position: static;
    }
  }

  @media (max-width: 620px) {
    h1 {
      font-size: 2.25rem;
    }
  }
</style>
