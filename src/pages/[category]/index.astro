---
import SectionHeading from "@/components/SectionHeading.astro";
import ResourceCard from "@/components/ResourceCard.astro";
import EditorialShell from "@/components/EditorialShell.astro";
import { categories } from "@/config/site";
import { getResourcesByCategory } from "@/lib/content/resources";
import { resourceSignals } from "@/lib/content/resource-display";
import BaseLayout from "@/layouts/BaseLayout.astro";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const categoryResources = await getResourcesByCategory(category.slug);
const categorySignals = Array.from(new Set(categoryResources.flatMap((resource) => resourceSignals(resource, 4)))).slice(0, 5);
---

<BaseLayout title={category.label} description={category.description} path={`/${category.slug}`}>
  <EditorialShell active={category.slug} eyebrow="Category" title={category.label} description={category.description}>
    <section class="category-summary">
      <div>
        <span>{categoryResources.length}</span>
        <p>published resources</p>
      </div>
      {
        categorySignals.length > 0 && (
          <div class="summary-signals">
            {categorySignals.map((signal) => <small>{signal}</small>)}
          </div>
        )
      }
      <a class="button secondary" href="/submit">Submit a project</a>
    </section>

    <section>
      <SectionHeading eyebrow="Directory" title={`Open ${category.label.toLowerCase()} worth reviewing`} />
      <div class="resource-list">
        {categoryResources.map((resource) => <ResourceCard resource={resource} />)}
      </div>
    </section>
  </EditorialShell>
</BaseLayout>

<style>
  .category-summary {
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    margin-bottom: 34px;
    padding: 18px;
  }

  .category-summary span {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
  }

  .category-summary p {
    margin: 4px 0 0;
  }

  .summary-signals {
    display: flex;
    flex: 1 1 auto;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .summary-signals small {
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 6px 9px;
  }

  .resource-list {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 920px) {
    .resource-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .category-summary {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
    }

    .resource-list {
      grid-template-columns: 1fr;
    }
  }
</style>
