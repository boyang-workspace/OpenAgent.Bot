---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="OpenAgent.bot is an editorial directory for open-source AI resources." path="/about">
  <section class="shell text-page">
    <span class="eyebrow">About</span>
    <h1 class="serif">A directory for the open AI stack.</h1>
    <p>
      OpenAgent.bot collects open-source AI models, agents, skills, memory systems,
      plugins, and tools into a stable discovery layer. The public site starts with
      curated pages and grows toward structured outputs that agents can read directly.
    </p>
  </section>
</BaseLayout>

<style>
  .text-page {
    max-width: 820px;
    padding-bottom: 80px;
    padding-top: 58px;
  }

  h1 {
    font-size: 3.5rem;
    line-height: 1;
    margin: 12px 0 0;
  }
</style>
