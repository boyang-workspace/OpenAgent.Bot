---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialShell from "@/components/EditorialShell.astro";
---

<BaseLayout title="About" description="OpenAgent.bot is an editorial directory for open-source AI resources." path="/about">
  <EditorialShell>
  <section class="text-page">
    <span class="eyebrow">About</span>
    <h1>A directory for the open AI stack.</h1>
    <p>
      OpenAgent.bot collects open-source AI models, agents, skills, memory systems,
      plugins, and tools into a stable discovery layer. The public site starts with
      curated pages and grows toward structured outputs that agents can read directly.
    </p>
  </section>
  </EditorialShell>
</BaseLayout>

<style>
  .text-page {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    max-width: 820px;
    padding: 32px;
  }

  h1 {
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    letter-spacing: -0.06em;
    line-height: 0.94;
    margin: 12px 0 0;
  }
</style>
