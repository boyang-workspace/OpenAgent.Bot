---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { categories, site } from "@/config/site";
import { labelForTag, tagGroupLabels, taxonomy } from "@/lib/content/taxonomy";

const taxonomyGroups = Object.entries(taxonomy).map(([group, values]) => ({
  group,
  label: tagGroupLabels[group as keyof typeof tagGroupLabels],
  values
}));
---

<AdminLayout title="Resources" active="projects">
  <section class="admin-grid">
    <div class="admin-panel">
      <div class="admin-actions" style="justify-content: space-between; margin-bottom: 16px;">
        <div>
          <span class="eyebrow">Resource drafts</span>
          <h2>Structured content queue</h2>
        </div>
        <button class="button secondary" id="refresh-projects" type="button">Refresh</button>
      </div>
      <div class="admin-list" id="projects-list">Loading drafts...</div>
    </div>

    <div class="admin-panel">
      <div class="admin-actions" style="justify-content: space-between; margin-bottom: 16px;">
        <div>
          <span class="eyebrow">Resource editor</span>
          <h2 id="editor-title">Select a resource draft</h2>
        </div>
        <a class="button secondary" id="preview-link" href="#" hidden>Preview URL</a>
      </div>
      <p class="admin-note">Resources are structured profiles for directory pages, search, SEO, and agent-readable output. Blog posts are managed separately in Blog. Drafts are not public until Publishing creates and merges a GitHub PR.</p>
      <form id="project-editor" class="admin-form" hidden>
        <input name="id" type="hidden" />
        <section class="admin-form-section">
          <header>
            <span class="eyebrow">Identity</span>
            <h3>What this resource is</h3>
            <p>Name, stable slug, and the compact description used by cards, search, and the profile hero.</p>
          </header>
          <div class="field-grid">
            <label>Title<input name="title" required /></label>
            <label>Slug<input name="slug" required /></label>
          </div>
          <label>One-liner<input name="oneLiner" required maxlength="180" /></label>
          <label>Summary<textarea name="summary" required></textarea></label>
        </section>

        <section class="admin-form-section">
          <header>
            <span class="eyebrow">Classification</span>
            <h3>Where it belongs</h3>
            <p>Category controls the public route. Tags are a temporary bridge until Taxonomy V1 replaces free text.</p>
          </header>
          <div class="field-grid">
            <label>
              Category
              <select name="category" required>
                {categories.map((category) => <option value={category.slug}>{category.label}</option>)}
              </select>
            </label>
            <label>Status<select name="status"><option value="draft">Draft</option><option value="ready">Ready</option></select></label>
            <label>Works with<input name="worksWith" placeholder="Comma-separated" /></label>
          </div>
          <input name="tags" type="hidden" />
          <div class="taxonomy-picker" aria-label="Controlled taxonomy tags">
            {taxonomyGroups.map((group) => (
              <fieldset>
                <legend>{group.label}</legend>
                <div>
                  {group.values.map((tag) => (
                    <label>
                      <input class="taxonomy-checkbox" name="taxonomyTag" type="checkbox" value={tag} data-group={group.group} />
                      <span>{labelForTag(tag)}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            ))}
          </div>
        </section>

        <section class="admin-form-section">
          <header>
            <span class="eyebrow">Positioning</span>
            <h3>Human decision content</h3>
            <p>These fields should help a reader decide whether the project is worth trying.</p>
          </header>
          <label>Why it matters<textarea name="whyItMatters" required></textarea></label>
          <div class="field-grid">
            <label>Best for<input name="bestFor" placeholder="Comma-separated" /></label>
            <label>Not for<input name="notFor" placeholder="Comma-separated" /></label>
          </div>
        </section>

        <section class="admin-form-section">
          <header>
            <span class="eyebrow">Facts & signals</span>
            <h3>Verifiable project facts</h3>
            <p>Keep facts separate from editorial judgment. Automation can update these later through reviewable PRs.</p>
          </header>
          <div class="field-grid">
            <label>License<input name="license" /></label>
            <label>Maintainer<input name="maintainer" /></label>
            <label>Install command<input name="installCommand" /></label>
            <label>
              Open-source status
              <select name="openSourceStatus">
                <option value="unknown">Unknown</option>
                <option value="open-source">Open source</option>
                <option value="open-core">Open core</option>
                <option value="source-available">Source available</option>
              </select>
            </label>
          </div>
          <div class="checkbox-row">
            <label><input name="isFeatured" type="checkbox" /> Featured</label>
            <label><input name="isSponsored" type="checkbox" /> Sponsored</label>
            <label><input name="noindex" type="checkbox" /> Noindex</label>
          </div>
        </section>

        <section class="admin-form-section">
          <header>
            <span class="eyebrow">Links & media</span>
            <h3>Where readers and agents go next</h3>
            <p>Primary source links power the detail page, JSON, Markdown, and future freshness checks.</p>
          </header>
          <div class="field-grid">
            <label>Repository URL<input name="repoUrl" type="url" /></label>
            <label>Homepage URL<input name="homepageUrl" type="url" /></label>
            <label>Docs URL<input name="docsUrl" type="url" /></label>
            <label>Demo URL<input name="demoUrl" type="url" /></label>
          </div>
          <label>Source links<input name="sourceLinks" placeholder="Comma-separated URLs" /></label>
          <label>Cover image<input name="coverImage" type="url" /></label>
        </section>

        <section class="admin-form-section">
          <header>
            <span class="eyebrow">SEO & share</span>
            <h3>Search and distribution</h3>
            <p>SEO fields shape search snippets. Share fields are used by social previews and editorial cards.</p>
          </header>
          <label>SEO title<input name="seoTitle" required maxlength="80" /></label>
          <label>SEO description<textarea name="seoDescription" required maxlength="180"></textarea></label>
          <div class="field-grid">
            <label>Share title<input name="shareTitle" required /></label>
            <label>Share description<input name="shareDescription" required /></label>
            <label>Featured reason<input name="featuredReason" /></label>
          </div>
        </section>

        <section class="admin-form-section">
          <header>
            <span class="eyebrow">Machine-readable preview</span>
            <h3>Stable agent endpoints</h3>
            <p>These URLs are generated from category and slug. They should not be edited by hand.</p>
          </header>
          <div class="admin-machine-preview" id="machine-preview" data-site={site.url}>
            <code>HTML: Select a draft</code>
            <code>JSON: Select a draft</code>
            <code>Markdown: Select a draft</code>
          </div>
        </section>
        <button class="button" type="submit">Save draft</button>
        <p id="editor-status" class="form-status" role="status"></p>
      </form>
    </div>
  </section>
</AdminLayout>

<script is:inline>
  const categories = new Set(["models", "agents", "memory-systems", "skills", "plugins", "tools"]);
  const arrayToText = (value) => Array.isArray(value) ? value.join(", ") : "";
  const textToArray = (value) => String(value ?? "").split(",").map((item) => item.trim()).filter(Boolean);
  const escapeHtml = (value) => String(value ?? "").replace(/[&<>"']/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" })[char]);
  let selectedProject = null;

  function selectedTaxonomyTags() {
    return Array.from(document.querySelectorAll(".taxonomy-checkbox:checked")).map((field) => field instanceof HTMLInputElement ? field.value : "").filter(Boolean);
  }

  function setTaxonomySelections(tags) {
    const selected = new Set(Array.isArray(tags) ? tags : []);
    document.querySelectorAll(".taxonomy-checkbox").forEach((field) => {
      if (field instanceof HTMLInputElement) field.checked = selected.has(field.value);
    });
    const editor = document.querySelector("#project-editor");
    const hidden = editor instanceof HTMLFormElement ? editor.elements.namedItem("tags") : null;
    if (hidden instanceof HTMLInputElement) hidden.value = Array.from(selected).join(", ");
  }

  async function api(path, options = {}) {
    const response = await fetch(path, { ...options, headers: { "content-type": "application/json", ...(options.headers ?? {}) } });
    const result = await response.json().catch(() => ({}));
    if (!response.ok || !result.ok) throw new Error(result.error ?? "Request failed.");
    return result;
  }

  function statusHint(project) {
    if (project.status === "pr_created") return "PR created, waiting for merge";
    if (project.status === "ready") return "Ready to create publish PR";
    if (project.status === "published") return "Published";
    return "Draft, not public yet";
  }

  function resourceType(category) {
    const map = {
      "models": "model",
      "agents": "agent",
      "memory-systems": "memory_system",
      "skills": "skill",
      "plugins": "plugin",
      "tools": "tool"
    };
    return map[category] ?? "tool";
  }

  function updateMachinePreview() {
    const editor = document.querySelector("#project-editor");
    const preview = document.querySelector("#machine-preview");
    if (!(editor instanceof HTMLFormElement) || !(preview instanceof HTMLElement)) return;
    if (editor.hidden) {
      preview.innerHTML = "<code>HTML: Select a draft</code><code>JSON: Select a draft</code><code>Markdown: Select a draft</code>";
      return;
    }
    const siteUrl = preview.dataset.site || "https://www.openagent.bot";
    const categoryField = editor.elements.namedItem("category");
    const slugField = editor.elements.namedItem("slug");
    const category = categoryField instanceof HTMLSelectElement ? categoryField.value : "";
    const slug = slugField instanceof HTMLInputElement ? slugField.value : "";
    if (!category || !slug) {
      preview.innerHTML = "<code>HTML: Select a draft</code><code>JSON: Select a draft</code><code>Markdown: Select a draft</code>";
      return;
    }
    const path = `/${category}/${slug}`;
    preview.innerHTML = `
      <code>Type: ${escapeHtml(resourceType(category))}</code>
      <code>HTML: ${escapeHtml(siteUrl + path)}</code>
      <code>JSON: ${escapeHtml(siteUrl + path + ".json")}</code>
      <code>Markdown: ${escapeHtml(siteUrl + path + ".md")}</code>
    `;
  }

  async function loadProjects() {
    const list = document.querySelector("#projects-list");
    if (!(list instanceof HTMLElement)) return;
    list.textContent = "Loading drafts...";
    try {
      const result = await api("/admin/api/projects");
      const projects = result.projects ?? [];
      list.innerHTML = projects.length ? projects.map((item) => `
        <article class="admin-item">
          <div>
            <strong>${escapeHtml(item.title)}</strong>
            <p>${escapeHtml(item.content.oneLiner ?? "")}</p>
            <small>${escapeHtml(item.category)} · ${escapeHtml(item.operation ?? "create")} · ${escapeHtml(item.status)} · ${escapeHtml(statusHint(item))}</small>
          </div>
          <div class="admin-actions">
            <button class="button secondary" data-edit="${item.id}" type="button">Edit</button>
            ${item.status === "ready" ? `<a class="button" href="/admin/publishing/?id=${item.id}">Publish</a>` : ""}
            ${item.prUrl ? `<a class="button secondary" href="${item.prUrl}" target="_blank" rel="noreferrer">Open PR</a>` : ""}
            <button class="button secondary danger" data-delete="${item.id}" type="button">Delete</button>
          </div>
        </article>
      `).join("") : "<p>No drafts yet.</p>";
    } catch (error) {
      list.innerHTML = `<p class="error-text">${error instanceof Error ? error.message : "Failed to load drafts."}</p>`;
    }
  }

  async function editProject(id) {
    const result = await api(`/admin/api/projects/${id}`);
    selectedProject = result.project;
    const editor = document.querySelector("#project-editor");
    const title = document.querySelector("#editor-title");
    const preview = document.querySelector("#preview-link");
    if (!(editor instanceof HTMLFormElement) || !(title instanceof HTMLElement)) return;
    editor.hidden = false;
    const operationLabel = selectedProject.operation === "update" ? "Update draft" : selectedProject.operation === "archive" ? "Unpublish draft" : "Create draft";
    title.textContent = `${operationLabel}: ${selectedProject.title}`;
    if (preview instanceof HTMLAnchorElement) {
      preview.hidden = false;
      preview.href = `/${selectedProject.category}/${selectedProject.slug}`;
    }
    const content = selectedProject.content;
    const fields = {
      id: selectedProject.id,
      status: selectedProject.status === "ready" ? "ready" : "draft",
      ...content,
      bestFor: arrayToText(content.bestFor),
      notFor: arrayToText(content.notFor),
      tags: arrayToText(content.tags),
      worksWith: arrayToText(content.worksWith),
      sourceLinks: arrayToText(content.sourceLinks)
    };
    for (const [key, value] of Object.entries(fields)) {
      const field = editor.elements.namedItem(key);
      if (field instanceof HTMLInputElement && field.type === "checkbox") field.checked = Boolean(value);
      else if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) field.value = value ?? "";
    }
    setTaxonomySelections(content.tags);
    const slugField = editor.elements.namedItem("slug");
    if (slugField instanceof HTMLInputElement) slugField.readOnly = selectedProject.operation === "update";
    const statusField = editor.elements.namedItem("status");
    if (statusField instanceof HTMLSelectElement) statusField.disabled = selectedProject.operation === "archive";
    updateMachinePreview();
  }

  function editorPayload() {
    const editor = document.querySelector("#project-editor");
    if (!(editor instanceof HTMLFormElement)) throw new Error("Editor is not ready.");
    const data = Object.fromEntries(new FormData(editor).entries());
    const category = String(data.category ?? "");
    if (!categories.has(category)) throw new Error("Invalid category.");
    return {
      ...data,
      bestFor: textToArray(data.bestFor),
      notFor: textToArray(data.notFor),
      tags: selectedTaxonomyTags(),
      worksWith: textToArray(data.worksWith),
      sourceLinks: textToArray(data.sourceLinks),
      isFeatured: Boolean(editor.querySelector("[name='isFeatured']")?.checked),
      isSponsored: Boolean(editor.querySelector("[name='isSponsored']")?.checked),
      noindex: Boolean(editor.querySelector("[name='noindex']")?.checked)
    };
  }

  async function saveProject(event) {
    event.preventDefault();
    const editor = document.querySelector("#project-editor");
    const status = document.querySelector("#editor-status");
    if (!(editor instanceof HTMLFormElement) || !(status instanceof HTMLElement)) return;
    const idField = editor.elements.namedItem("id");
    const id = idField instanceof HTMLInputElement ? idField.value : "";
    status.textContent = "Saving...";
    status.dataset.state = "";
    try {
      const result = await api(`/admin/api/projects/${id}`, { method: "PUT", body: JSON.stringify(editorPayload()) });
      selectedProject = result.project;
      status.textContent = "Saved. Draft is still not public until a publish PR is merged.";
      status.dataset.state = "success";
      updateMachinePreview();
      await loadProjects();
    } catch (error) {
      status.textContent = error instanceof Error ? error.message : "Save failed.";
      status.dataset.state = "error";
    }
  }

  async function deleteProject(id) {
    if (!confirm("Delete this draft from the admin queue? This does not delete any already-live GitHub file.")) return;
    const status = document.querySelector("#editor-status");
    if (status instanceof HTMLElement) {
      status.textContent = "Deleting draft...";
      status.dataset.state = "";
    }
    try {
      await api(`/admin/api/projects/${id}`, { method: "DELETE" });
      if (selectedProject?.id === id) {
        selectedProject = null;
        const editor = document.querySelector("#project-editor");
        const title = document.querySelector("#editor-title");
        const preview = document.querySelector("#preview-link");
        if (editor instanceof HTMLFormElement) editor.hidden = true;
        if (title instanceof HTMLElement) title.textContent = "Select a resource draft";
        if (preview instanceof HTMLAnchorElement) preview.hidden = true;
        updateMachinePreview();
      }
      if (status instanceof HTMLElement) {
        status.textContent = "Draft deleted.";
        status.dataset.state = "success";
      }
      await loadProjects();
    } catch (error) {
      if (status instanceof HTMLElement) {
        status.textContent = error instanceof Error ? error.message : "Delete failed.";
        status.dataset.state = "error";
      }
    }
  }

  document.querySelector("#refresh-projects")?.addEventListener("click", loadProjects);
  document.querySelector("#projects-list")?.addEventListener("click", (event) => {
    const target = event.target;
    if (target instanceof HTMLButtonElement && target.dataset.edit) editProject(target.dataset.edit);
    if (target instanceof HTMLButtonElement && target.dataset.delete) deleteProject(target.dataset.delete);
  });
  document.querySelector("#project-editor")?.addEventListener("submit", saveProject);
  document.querySelector("#project-editor")?.addEventListener("input", updateMachinePreview);
  document.querySelector("#project-editor")?.addEventListener("change", updateMachinePreview);

  const initialId = new URL(location.href).searchParams.get("id");
  loadProjects().then(() => initialId && editProject(initialId));
</script>
