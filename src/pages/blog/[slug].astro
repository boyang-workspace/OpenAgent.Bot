---
import { getPublishedBlogPosts } from "@/lib/content/blog";
import EditorialShell from "@/components/EditorialShell.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
---

<BaseLayout
  title={post.seoTitle ?? post.title}
  description={post.seoDescription ?? post.summary}
  path={`/blog/${post.slug}`}
>
  <EditorialShell active="blog">
  <article class="article">
    <span class="eyebrow">{post.publishedAt} · {post.author}</span>
    <h1>{post.title}</h1>
    <p class="dek">{post.summary}</p>
    <div class="body">
      <p>{post.body}</p>
    </div>
  </article>
  </EditorialShell>
</BaseLayout>

<style>
  .article {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    max-width: 820px;
    padding: 32px;
  }

  h1 {
    font-size: 4rem;
    letter-spacing: 0;
    line-height: 1;
    margin: 12px 0 0;
  }

  .dek {
    font-size: 1.18rem;
  }

  .body {
    border-top: 1px solid var(--line);
    margin-top: 32px;
    padding-top: 28px;
  }

  .body p {
    color: var(--ink);
    font-size: 1.08rem;
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 2.4rem;
    }

    .article {
      padding: 20px;
    }
  }
</style>
