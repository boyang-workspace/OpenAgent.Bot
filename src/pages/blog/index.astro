---
import EditorialShell from "@/components/EditorialShell.astro";
import { posts } from "@/data/posts";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Blog" description="Editorial notes about open-source AI resources, agent tooling, and machine-readable discovery." path="/blog">
  <EditorialShell
    active="blog"
    eyebrow="Blog"
    title="Notes for the open AI resource graph"
    description="Short essays, curation notes, and practical thinking for builders navigating open AI infrastructure."
  >
  <section class="post-index">
    {
      posts.map((post) => (
        <a href={`/blog/${post.slug}`}>
          <span>{post.publishedAt}</span>
          <h2>{post.title}</h2>
          <p>{post.summary}</p>
          <div>{post.tags.map((tag) => <small>{tag}</small>)}</div>
        </a>
      ))
    }
  </section>
  </EditorialShell>
</BaseLayout>

<style>
  .post-index {
    display: grid;
    gap: 18px;
  }

  .post-index a {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 8px;
    padding: 22px;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .post-index a:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  span {
    color: var(--red);
    font-weight: 750;
  }

  h2 {
    font-size: 2rem;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0;
  }

  p {
    margin: 0;
    max-width: 780px;
  }

  div {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  small {
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    padding: 5px 9px;
  }
</style>
