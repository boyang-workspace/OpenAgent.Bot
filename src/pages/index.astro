---
import ResourceCard from "@/components/ResourceCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import EditorialShell from "@/components/EditorialShell.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories } from "@/config/site";
import { posts } from "@/data/posts";
import { getPublishedResources, resourcePath } from "@/lib/content/resources";
import { resourceCategoryLabel, resourceImage } from "@/lib/content/resource-display";

const resources = await getPublishedResources();
const today = resources.find((resource) => resource.editorial?.featured_reason) ?? resources[0];
const trending = resources
  .filter((resource) => resource.editorial?.featured_reason || resource.facts.github_stars)
  .sort((a, b) => (b.facts.github_stars ?? 0) - (a.facts.github_stars ?? 0))
  .slice(0, 3);
const recent = [...resources].sort((a, b) => b.timestamps.updated_at.localeCompare(a.timestamps.updated_at)).slice(0, 3);
const todayPath = today ? resourcePath(today) : undefined;
const todayCategory = today ? resourceCategoryLabel(today) : undefined;
---

<BaseLayout>
  <EditorialShell active="today">
    <section id="today" class="today-panel">
      <div class="today-copy">
        <span class="eyebrow">Today Feature</span>
        <h1>Open AI resources, edited like an app store.</h1>
        <p>
          Find models, agents, skills, memory systems, plugins, and tools with stable routes,
          source links, and machine-readable profiles.
        </p>
        <div class="hero-actions">
          {todayPath && <a class="button" href={todayPath}>Read today's pick</a>}
          <a class="button secondary" href="/submit">Submit a project</a>
        </div>
      </div>
      {
        today && (
          <a class="featured-project" href={todayPath}>
            <img src={resourceImage(today)} alt="" loading="eager" />
            <div class="featured-copy">
              <div class="featured-meta">
                <span>{todayCategory}</span>
              </div>
              <h2>{today.identity.name}</h2>
              <p>{today.identity.one_liner}</p>
              {today.editorial?.featured_reason && <p class="featured-reason">{today.editorial.featured_reason}</p>}
              <span class="featured-cta">Read profile</span>
            </div>
          </a>
        )
      }
    </section>

    <section id="trending" class="section">
      <SectionHeading
        eyebrow="Trending"
        title="Projects getting attention across the open AI stack"
        description="A short editorial shelf for tools with useful momentum, active communities, or strong agent-native relevance."
      />
      <div class="shelf-grid">
        {trending.map((resource) => <ResourceCard resource={resource} />)}
      </div>
    </section>

    <section id="recent" class="section soft-section">
      <SectionHeading eyebrow="Recently Added" title="Fresh entries for builders and researchers" />
      <div class="shelf-grid">
        {recent.map((resource) => <ResourceCard resource={resource} />)}
      </div>
    </section>

    <section class="section">
      <SectionHeading eyebrow="Categories" title="Browse by resource type" />
      <div class="category-grid">
        {
          categories.map((category) => (
            <a class="category" href={`/${category.slug}`}>
              <span>{category.label}</span>
              <p>{category.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section soft-section">
      <div class="blog-strip">
        <div>
          <SectionHeading eyebrow="From the Blog" title="Editorial notes for open AI discovery" />
        </div>
        <div class="post-list">
          {
            posts.slice(0, 3).map((post) => (
              <a href={`/blog/${post.slug}`}>
                <span>{post.publishedAt}</span>
                <strong>{post.title}</strong>
                <p>{post.summary}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section mission">
      <span class="eyebrow">Mission</span>
      <h2>Make open AI resources easier to find, compare, cite, and consume.</h2>
      <p>
        OpenAgent.bot starts with a public directory and grows toward structured Markdown,
        JSON, manifests, and practical workflows for agents.
      </p>
      <a class="button" href="/manifesto">Read the manifesto</a>
    </section>
  </EditorialShell>
</BaseLayout>

<style>
  .today-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-feature);
    display: grid;
    gap: 16px;
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1.3fr);
    min-height: 460px;
    min-width: 0;
    overflow: hidden;
  }

  .today-copy {
    align-content: center;
    display: grid;
    min-width: 0;
    padding: 30px;
  }

  h1 {
    font-size: clamp(2.4rem, 4.5vw, 3.9rem);
    letter-spacing: 0;
    line-height: 1;
    margin: 12px 0 0;
    max-width: 100%;
  }

  .today-copy p {
    font-size: 1.03rem;
    margin: 20px 0 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .featured-project {
    display: grid;
    grid-template-rows: minmax(220px, 1fr) auto;
    min-width: 0;
    overflow: hidden;
  }

  .featured-project img {
    background: var(--surface-tint);
    height: 100%;
    max-width: 100%;
    object-fit: cover;
    width: 100%;
  }

  .featured-copy {
    border-left: 1px solid var(--line);
    display: grid;
    gap: 10px;
    min-width: 0;
    padding: 20px;
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .featured-meta span {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .featured-meta span:first-child {
    color: var(--accent-open);
  }

  .featured-copy h2 {
    font-size: 2.6rem;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
  }

  .featured-copy p {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .featured-reason {
    color: var(--ink);
    display: -webkit-box;
    font-size: 0.9rem;
    line-height: 1.55;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .featured-cta {
    color: var(--accent-open);
    font-size: 0.82rem;
    font-weight: 600;
    margin-top: 4px;
  }

  .shelf-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .soft-section {
    background: var(--surface-tint);
    border-radius: 8px;
    margin: 38px 0;
    padding: 28px;
  }

  .category-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    min-height: 150px;
    padding: 18px;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .category:hover {
    background: var(--surface-soft);
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }

  .category span {
    font-size: 1.22rem;
    font-weight: 700;
  }

  .blog-strip {
    display: grid;
    gap: 32px;
    grid-template-columns: 0.8fr 1.2fr;
  }

  .post-list {
    display: grid;
    gap: 14px;
  }

  .post-list a {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 6px;
    padding: 16px;
  }

  .post-list span {
    color: var(--red);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .post-list strong {
    font-size: 1.15rem;
  }

  .post-list p {
    margin: 0;
  }

  .mission {
    max-width: 860px;
  }

  .mission h2 {
    font-size: 2.6rem;
    letter-spacing: 0;
    line-height: 1.08;
    margin: 10px 0 0;
  }

  @media (max-width: 920px) {
    .today-panel,
    .blog-strip {
      grid-template-columns: 1fr;
    }

    .featured-copy {
      border-left: 0;
      border-top: 1px solid var(--line);
    }

    h1 {
      font-size: 3rem;
    }

    .category-grid,
    .shelf-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    h1,
    .mission h2 {
      font-size: 2rem;
      letter-spacing: 0;
      line-height: 1.05;
    }

    .category-grid,
    .shelf-grid {
      grid-template-columns: 1fr;
    }

    .today-copy,
    .soft-section {
      padding: 18px;
    }

    .today-panel {
      min-height: 0;
      max-width: 100%;
      width: 100%;
    }

    .hero-actions .button {
      flex: 1 1 100%;
      width: 100%;
    }

    .featured-project,
    .featured-copy {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
