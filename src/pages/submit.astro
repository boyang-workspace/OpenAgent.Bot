---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialShell from "@/components/EditorialShell.astro";
---

<BaseLayout title="Submit" description="Submit an open-source AI project for future review." path="/submit">
  <EditorialShell>
  <section class="submit">
    <div>
      <span class="eyebrow">Submit</span>
      <h1>Share an open AI project.</h1>
      <p>
        The first public build uses a static placeholder. The submission workflow will
        move into the admin and review system after the content schema is stable.
      </p>
    </div>
    <form>
      <label>
        Project name
        <input name="name" placeholder="Project name" disabled />
      </label>
      <label>
        Repository URL
        <input name="repo" placeholder="https://github.com/..." disabled />
      </label>
      <label>
        Summary
        <textarea name="summary" placeholder="What should builders know?" disabled></textarea>
      </label>
      <button class="button" type="button" disabled>Submissions open soon</button>
    </form>
  </section>
  </EditorialShell>
</BaseLayout>

<style>
  .submit {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 34px;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
    padding: 32px;
  }

  h1 {
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    letter-spacing: -0.06em;
    line-height: 0.94;
    margin: 12px 0 0;
  }

  form {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 16px;
    padding: 22px;
  }

  label {
    color: var(--muted);
    display: grid;
    font-weight: 700;
    gap: 8px;
  }

  input,
  textarea {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    font: inherit;
    min-height: 44px;
    padding: 10px 12px;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  @media (max-width: 780px) {
    .submit {
      grid-template-columns: 1fr;
    }
  }
</style>
